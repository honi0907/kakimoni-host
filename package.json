{
  "name": "kakimoni-host",
  "version": "1.0.7",
  "description": "KakiMoni 親機アプリ",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.10.0"
  },
  "build": {
    "appId": "jp.honi0907.kakimoni.host",
    "productName": "KakiMoni_Host",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "artifactName": "KakiMoni_Host-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
